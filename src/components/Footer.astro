---
import Logo from "../svgs/Logo.svg?raw";

const today = new Date();
---

<footer class="border-t border-border py-12">
    <div class="max-w-3xl mx-auto px-6 flex flex-col items-center gap-5 text-muted">
        <p class="m-0 text-sm text-center">
            <a href="https://github.com/antoinekahlouche/blog" target="_blank">
                This site is open source!
            </a>
            <br />
            &copy; {today.getFullYear()} Antoine Kahlouche.
        </p>
        <div class="flex justify-center w-full">
            <Fragment set:html={Logo} />
        </div>
    </div>
</footer>
